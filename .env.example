# ═══════════════════════════════════════
# TAO VPN SuperApp — Environment
# ═══════════════════════════════════════

# --- Core ---
PORT=9797
HOST=0.0.0.0
NODE_ENV=production
PUBLIC_URL=https://taovpn.com
# Generate: openssl rand -base64 48
JWT_SECRET=REPLACE_ME

# --- Web Push ---
# Generate once: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:iotaovpn@gmail.com

# --- SMS (MTS Exolve) ---
EXOLVE_API_TOKEN=
EXOLVE_SENDER=TAO_VPN

# --- Email SMTP (пусто = stub mode, коды в логах) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=TAO VPN <iotaovpn@gmail.com>

# --- Telegram bot ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=taovpn_bot

# --- Matrix / Synapse (TAO SPACE integration) ---
# Internal Synapse URL (docker network or localhost)
SYNAPSE_URL=http://tao-space-synapse:8008
# Public URL for clients
SYNAPSE_PUBLIC_URL=https://space.taodev.net
# Server name from homeserver.yaml
SYNAPSE_DOMAIN=space.taodev.net
# From homeserver.yaml → registration_shared_secret
# Get it: grep registration_shared_secret /path/to/synapse-data/homeserver.yaml
SYNAPSE_SHARED_SECRET=
# Alternative: admin user access token (if no shared secret)
SYNAPSE_ADMIN_TOKEN=
