# --- Core ---
PUBLIC_URL=https://vpn.taodev.net
# Generate: openssl rand -base64 48
JWT_SECRET=replace-with-random-48-byte-secret-please

# --- Web Push (generate once: npx web-push generate-vapid-keys) ---
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@taodev.net

# --- SMS (MTS Exolve) ---
# Get token: https://hub.exolve.ru/
EXOLVE_API_TOKEN=
EXOLVE_SENDER=TAO_VPN

# --- Email SMTP (Yandex / Mail.ru / Gmail / your own) ---
SMTP_HOST=smtp.yandex.ru
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=noreply@taodev.net
SMTP_PASS=
SMTP_FROM=TAO VPN <noreply@taodev.net>

# --- Telegram bot ---
# Create via @BotFather. Username WITHOUT @
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=TaoVPNBot
